# Supabase project URL — Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Public anon key — safe to expose to the browser. Used for all read-only
# queries on the public site (RLS restricts it to published content only).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to the browser. Used only in server-side
# code (route handlers, /admin pages with "use server") to bypass RLS for
# writes made through the CMS. Keep this out of any NEXT_PUBLIC_ variable.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
